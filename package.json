{
  "name": "andesoricore-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:landingpage",
    "build": "npm run build:landingpage",
    "dev:landingpage": "npm run dev --workspace @andesoricore/landingpage",
    "build:landingpage": "npm run build --workspace @andesoricore/landingpage",
    "start:landingpage": "npm run start --workspace @andesoricore/landingpage",
    "lint:landingpage": "npm run lint --workspace @andesoricore/landingpage",
    "dev:wiki": "npm run dev --workspace @andesoricore/wiki",
    "build:wiki": "npm run build --workspace @andesoricore/wiki",
    "start:wiki": "npm run start --workspace @andesoricore/wiki",
    "lint:wiki": "npm run lint --workspace @andesoricore/wiki"
  }
}